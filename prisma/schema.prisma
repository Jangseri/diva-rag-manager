generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Document {
  file_id         String   @id @db.VarChar(26)
  source_type     String   @default("file") @db.VarChar(10)
  source_url      String?  @db.VarChar(2048)
  file_name       String   @db.VarChar(500)
  user_key        String   @db.VarChar(100)
  file_format     String?  @db.VarChar(20)
  file_size       BigInt   @db.BigInt
  file_status     String   @default("UPLOADED") @db.VarChar(20)
  collection_name String?  @db.VarChar(200)
  origin_path     String?  @db.VarChar(1000)
  retry_count     Int      @default(0)
  last_error_code String?  @db.VarChar(50)
  rgst_dt         DateTime @default(now()) @db.DateTime(0)
  rgst_nm         String   @db.VarChar(100)
  status          String   @default("ACTIVE") @db.VarChar(10)
  updt_dt         DateTime @updatedAt @db.DateTime(0)
  updt_nm         String   @db.VarChar(100)

  @@index([source_type])
  @@map("document_files")
}

/// 멱등성 보장용 처리된 이벤트 기록
model ProcessedEvent {
  event_id     String   @id @db.VarChar(30)
  event_type   String   @db.VarChar(50)
  file_id      String?  @db.VarChar(26)
  processed_at DateTime @default(now()) @db.DateTime(0)

  @@index([file_id])
  @@map("processed_events")
}

/// 분산 삭제 confirmation 추적 (EXTRACT_DELETED + INDEX_DELETED 대기)
model DeletionConfirmation {
  file_id              String    @id @db.VarChar(26)
  extract_confirmed    Boolean   @default(false)
  extract_error_code   String?   @db.VarChar(50)
  extract_confirmed_at DateTime? @db.DateTime(0)
  index_confirmed      Boolean   @default(false)
  index_error_code     String?   @db.VarChar(50)
  index_confirmed_at   DateTime? @db.DateTime(0)
  deletion_due_at      DateTime  @db.DateTime(0)
  finalized_at         DateTime? @db.DateTime(0)
  created_at           DateTime  @default(now()) @db.DateTime(0)
  updated_at           DateTime  @updatedAt @db.DateTime(0)

  @@index([finalized_at, deletion_due_at])
  @@map("deletion_confirmations")
}
